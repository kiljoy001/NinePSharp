{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "NinePSharp/NinePSharp.csproj",
            "NinePSharp.Parser/NinePSharp.Parser.fsproj",
            "NinePSharp.Server/NinePSharp.Server.csproj",
            "NinePSharp.Server.Abstractions/NinePSharp.Server.Abstractions.csproj",
            "NinePSharp.Backends.Blockchain/NinePSharp.Backends.Blockchain.csproj",
            "NinePSharp.Backends.Cloud/NinePSharp.Backends.Cloud.csproj",
            "NinePSharp.Backends.Pipes/NinePSharp.Backends.Pipes.csproj",
            "NinePSharp.Backends.PowerShell/NinePSharp.Backends.PowerShell.csproj",
            "NinePSharp.Core.FSharp/NinePSharp.Core.FSharp.fsproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**"
          ]
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "docs/conceptual/**.md",
          "docs/conceptual/toc.yml",
          "toc.yml",
          "index.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "docs/images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}
