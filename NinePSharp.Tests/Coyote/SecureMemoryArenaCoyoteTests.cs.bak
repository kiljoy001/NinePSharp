using System;
using System.Linq;
using System.Threading.Tasks;
using Xunit;
using Microsoft.Coyote.SystematicTesting;
using NinePSharp.Server.Utils;
using FluentAssertions;

namespace NinePSharp.Tests.Coyote;

public class SecureMemoryArenaCoyoteTests
{
    [Fact]
    public void Arena_Handles_Concurrent_Slab_Churn()
    {
        var configuration = Microsoft.Coyote.Configuration.Create()
            .WithTestingIterations(200)
            .WithMaxSchedulingSteps(500);

        var engine = TestingEngine.Create(configuration, async () =>
        {
            // Use a smaller arena for Coyote to stress overflow and recycling faster
            using var arena = new SecureMemoryArena(64 * 1024); // 64KB

            // Concurrent Task 1: Allocation and immediately free
            var task1 = Task.Run(() =>
            {
                for (int i = 0; i < 50; i++)
                {
                    var slice = arena.Allocate(256); // Slab allocation
                    arena.Free(slice);
                }
            });

            // Concurrent Task 2: Mixed sizes (Slab + Overflow)
            var task2 = Task.Run(() =>
            {
                for (int i = 0; i < 50; i++)
                {
                    var size = (i % 2 == 0) ? 32 : 123; // Slab or Overflow
                    var slice = arena.Allocate(size);
                    arena.Free(slice);
                }
            });

            // Concurrent Task 3: Allocation with brief hold
            var task3 = Task.Run(async () =>
            {
                for (int i = 0; i < 20; i++)
                {
                    var slice = arena.Allocate(1024);
                    // Coyote/C# limitation: Span cannot be used after 'await'.
                    // We must free it manually before the await if we don't need it, 
                    // or use unsafe pointers.
                    arena.Free(slice);
                    await Task.Yield(); // Encourage Coyote scheduling
                }
            });

            await Task.WhenAll(task1, task2, task3);

            // Invariant: After all tasks complete, ActiveAllocations MUST be 0
            arena.ActiveAllocations.Should().Be(0, "Arena must have 0 active allocations after all concurrent tasks finish.");
        });

        engine.Run();
        Assert.True(engine.TestReport.NumOfFoundBugs == 0, 
            $"Coyote found {engine.TestReport.NumOfFoundBugs} bugs in SecureMemoryArena. {string.Join(Environment.NewLine, engine.TestReport.BugReports)}");
    }

    [Fact]
    public void Arena_Overflow_Reset_Safety_Test()
    {
        // This test specifically targets the 'lock' and 'reset' logic in SecureMemoryArena.cs line 110
        var configuration = Microsoft.Coyote.Configuration.Create()
            .WithTestingIterations(100);

        var engine = TestingEngine.Create(configuration, async () =>
        {
            using var arena = new SecureMemoryArena(4096); // Very small arena to force resets

            // Task 1: Fill the overflow region
            var task1 = Task.Run(async () => {
                var s1 = arena.Allocate(2000); // Fills ~half
                arena.Free(s1); // Free BEFORE yield to avoid CS4007
                await Task.Yield();
            });

            // Task 2: Fill and trigger potential reset
            var task2 = Task.Run(async () => {
                var s2 = arena.Allocate(3000); // Forces reset if task1 freed
                arena.Free(s2); // Free BEFORE yield to avoid CS4007
                await Task.Yield();
            });

            await Task.WhenAll(task1, task2);
            arena.ActiveAllocations.Should().Be(0);
        });

        engine.Run();
        Assert.True(engine.TestReport.NumOfFoundBugs == 0);
    }
}
