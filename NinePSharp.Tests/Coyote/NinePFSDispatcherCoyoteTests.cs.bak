using System;
using System.Linq;
using System.Threading.Tasks;
using Xunit;
using Microsoft.Coyote.SystematicTesting;
using NinePSharp.Server;
using NinePSharp.Server.Interfaces;
using NinePSharp.Server.Cluster;
using NinePSharp.Messages;
using NinePSharp.Protocol;
using NinePSharp.Parser;
using NinePSharp.Server.Utils;
using NinePSharp.Constants;
using Moq;

namespace NinePSharp.Tests.Coyote;

public class NinePFSDispatcherCoyoteTests
{
    private ClusterManager CreateMockClusterManager()
    {
        var logger = new Mock<Microsoft.Extensions.Logging.ILogger<ClusterManager>>();
        var factory = new Mock<Microsoft.Extensions.Logging.ILoggerFactory>();
        var config = new NinePSharp.Server.Configuration.Models.ServerConfig(); 
        return new ClusterManager(logger.Object, factory.Object, config);
    }

    private class TestLogger<T> : Microsoft.Extensions.Logging.ILogger<T>
    {
        public IDisposable? BeginScope<TState>(TState state) where TState : notnull => null;
        public bool IsEnabled(Microsoft.Extensions.Logging.LogLevel logLevel) => true;
        public void Log<TState>(Microsoft.Extensions.Logging.LogLevel logLevel, Microsoft.Extensions.Logging.EventId eventId, TState state, Exception? exception, Func<TState, Exception?, string> formatter) { }
    }

    [Fact]
    public void Dispatcher_Handles_Concurrent_Fid_Lifecycle()
    {
        // 1. Configure the Coyote test engine
        var configuration = Microsoft.Coyote.Configuration.Create()
            .WithTestingIterations(100)
            .WithMaxSchedulingSteps(200);

        // 2. Run the systematic test
        var engine = TestingEngine.Create(configuration, async () =>
        {
            // Setup a mock dispatcher
            var logger = new TestLogger<NinePFSDispatcher>();
            var mockBackend = new Mock<IProtocolBackend>();
            mockBackend.Setup(b => b.Name).Returns("mock");
            mockBackend.Setup(b => b.MountPath).Returns("/mock");
            var mockFs = new Mock<INinePFileSystem>();
            mockFs.Setup(f => f.Clone()).Returns(mockFs.Object);
            mockFs.Setup(f => f.WalkAsync(It.IsAny<Twalk>())).ReturnsAsync(new Rwalk(1, new[] { new Qid(QidType.QTFILE, 0, 1) }));
            mockFs.Setup(f => f.ClunkAsync(It.IsAny<Tclunk>())).ReturnsAsync(new Rclunk(1));
            mockBackend.Setup(b => b.GetFileSystem(It.IsAny<System.Security.SecureString>(), It.IsAny<System.Security.Cryptography.X509Certificates.X509Certificate2>())).Returns(mockFs.Object);
            
            var dispatcher = new NinePFSDispatcher(logger, new[] { mockBackend.Object }, CreateMockClusterManager());

            // 3. Define the concurrent operations
            
            // Client 1: Attaches to FID 100, then clunks it
            var task1 = Task.Run(async () =>
            {
                var attach = new Tattach(1, 100, NinePConstants.NoFid, "user1", "mock");
                await dispatcher.DispatchAsync(NinePMessage.NewMsgTattach(attach), false);
                
                var clunk = new Tclunk(2, 100);
                await dispatcher.DispatchAsync(NinePMessage.NewMsgTclunk(clunk), false);
            });

            // Client 2: Walks FID 100 to FID 101, then clunks FID 101
            var task2 = Task.Run(async () =>
            {
                // Wait briefly to encourage interleaving where task2 runs after task1 attaches but before it clunks
                await Task.Yield();
                
                var walk = new Twalk(3, 100, 101, new[] { "file.txt" });
                try 
                {
                    await dispatcher.DispatchAsync(NinePMessage.NewMsgTwalk(walk), false);
                    var clunk = new Tclunk(4, 101);
                    await dispatcher.DispatchAsync(NinePMessage.NewMsgTclunk(clunk), false);
                }
                catch (NinePProtocolException)
                {
                    // This is expected if task1 clunks FID 100 before task2 walks it.
                }
            });

            // Client 3: Tries to clunk FID 100 (a race condition with task1)
            var task3 = Task.Run(async () =>
            {
                await Task.Yield();
                var clunk = new Tclunk(5, 100);
                try
                {
                    await dispatcher.DispatchAsync(NinePMessage.NewMsgTclunk(clunk), false);
                }
                catch (NinePProtocolException)
                {
                    // Also expected
                }
            });

            // 4. Await all async tasks to let Coyote explore interleavings
            System.Threading.Tasks.Task.WaitAll(task1, task2, task3);
        });

        engine.Run();

        // 5. Check the result
        Assert.True(engine.TestReport.NumOfFoundBugs == 0, 
            $"Coyote found {engine.TestReport.NumOfFoundBugs} concurrency bugs. {string.Join(Environment.NewLine, engine.TestReport.BugReports)}");
    }

    [Fact]
    public void Dispatcher_Handles_Concurrent_Backend_Operations()
    {
        var configuration = Microsoft.Coyote.Configuration.Create()
            .WithTestingIterations(50)
            .WithMaxSchedulingSteps(200);

        var engine = TestingEngine.Create(configuration, async () =>
        {
            var logger = new TestLogger<NinePFSDispatcher>();
            var mockBackend = new Mock<IProtocolBackend>();
            mockBackend.Setup(b => b.Name).Returns("mock");
            mockBackend.Setup(b => b.MountPath).Returns("/mock");
            
            // We use a real ConcurrentDictionary internally to simulate state race
            var fileData = new System.Collections.Concurrent.ConcurrentDictionary<ulong, byte>();
            
            var mockFs = new Mock<INinePFileSystem>();
            mockFs.Setup(f => f.WriteAsync(It.IsAny<Twrite>())).Returns<Twrite>(async t => 
            {
                // Simulate some async I/O delay that Coyote can interleave
                await Task.Yield();
                
                for (int i = 0; i < t.Data.Length; i++)
                {
                    fileData.AddOrUpdate(t.Offset + (ulong)i, t.Data.Span[i], (_, _) => t.Data.Span[i]);
                }
                
                return new Rwrite(t.Tag, (uint)t.Data.Length);
            });
            mockBackend.Setup(b => b.GetFileSystem(It.IsAny<System.Security.SecureString>(), It.IsAny<System.Security.Cryptography.X509Certificates.X509Certificate2>())).Returns(mockFs.Object);
            
            var dispatcher = new NinePFSDispatcher(logger, new[] { mockBackend.Object }, CreateMockClusterManager());

            // Initial attach to get the FID
            var attach = new Tattach(1, 100, NinePConstants.NoFid, "user1", "mock");
            await dispatcher.DispatchAsync(NinePMessage.NewMsgTattach(attach), false);

            var writeData1 = new byte[] { 1, 1, 1, 1 };
            var task1 = Task.Run(async () =>
            {
                await Task.Yield();
                var write = new Twrite(2, 100, 0, writeData1);
                await dispatcher.DispatchAsync(NinePMessage.NewMsgTwrite(write), false);
            });

            var writeData2 = new byte[] { 2, 2, 2, 2 };
            var task2 = Task.Run(async () =>
            {
                await Task.Yield();
                var write = new Twrite(3, 100, 4, writeData2);
                await dispatcher.DispatchAsync(NinePMessage.NewMsgTwrite(write), false);
            });

            await System.Threading.Tasks.Task.WhenAll(task1, task2);

            // Verify both writes succeeded without data corruption
            Assert.Equal(8, fileData.Count);
        });

        engine.Run();
        Assert.True(engine.TestReport.NumOfFoundBugs == 0, 
            $"Coyote found {engine.TestReport.NumOfFoundBugs} concurrency bugs. {string.Join(Environment.NewLine, engine.TestReport.BugReports)}");
    }
}
